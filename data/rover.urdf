<?xml version="1.0"?>
<robot name="Pulsar Rover">

  <material name="chassis">
    <color rgba="0.23 0.23 0.23 1"/>
  </material>
  <material name="wheel">
    <color rgba="0.4 0.4 0.4 1"/>
  </material>
  <material name="antenna">
    <color rgba="0.5 0.5 0.5 1"/>
  </material>

  <link name="base_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="1.5 0.5 0.3"/>
      </geometry>
      <material name="chassis"/>
    </visual>
  </link>

  <link name="left_front_wheel">
    <visual>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry>
        <cylinder radius="0.15" length="0.12"/>
      </geometry>
      <material name="wheel"/>
    </visual>
  </link>

  <link name="right_front_wheel">
    <visual>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry>
        <cylinder radius="0.15" length="0.12"/>
      </geometry>
      <material name="wheel"/>
    </visual>
  </link>

  <link name="left_back_wheel">
    <visual>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry>
        <cylinder radius="0.15" length="0.12"/>
      </geometry>
      <material name="wheel"/>
    </visual>
  </link>

  <link name="right_back_wheel">
    <visual>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry>
        <cylinder radius="0.15" length="0.12"/>
      </geometry>
      <material name="wheel"/>
    </visual>
  </link>

  <link name="antenna">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.01" length="0.3"/>
      </geometry>
      <material name="antenna"/>
    </visual>
  </link>

  <joint name="base_to_left_front" type="fixed">
    <parent link="base_link"/>
    <child link="left_front_wheel"/>
    <origin xyz="0.5 -0.35 -0.2" rpy="0 0 0"/>
  </joint>

  <joint name="base_to_right_front" type="fixed">
    <parent link="base_link"/>
    <child link="right_front_wheel"/>
    <origin xyz="0.5 0.35 -0.2" rpy="0 0 0"/>
  </joint>

  <joint name="base_to_left_back" type="fixed">
    <parent link="base_link"/>
    <child link="left_back_wheel"/>
    <origin xyz="-0.5 -0.35 -0.2" rpy="0 0 0"/>
  </joint>

  <joint name="base_to_right_back" type="fixed">
    <parent link="base_link"/>
    <child link="right_back_wheel"/>
    <origin xyz="-0.5 0.35 -0.2" rpy="0 0 0"/>
  </joint>

  <joint name="base_to_antenna" type="fixed">
    <parent link="base_link"/>
    <child link="antenna"/>
    <origin xyz="0 0 0.15" rpy="0 0 0"/>
  </joint>

</robot>
