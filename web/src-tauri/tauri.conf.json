{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Panels ERC Edition",
  "version": "0.1.4",
  "identifier": "com.bylazar.panels-erc-edition",
  "build": {
    "frontendDist": "../build",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "bun run dev -- --host 127.0.0.1",
    "beforeBuildCommand": "bun run build"
  },
  "app": {
    "windows": [
      {
        "title": "Panels - ERC Edition",
        "width": 1280,
        "height": 820,
        "resizable": true,
        "fullscreen": false,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDVDNjgzQzhBMDI3QUVFQkEKUldTNjdub0NpanhvWEhwVFRHZlVaOHRIZ3FYSFoyN2pDNi9DL1I0dHJ3WjlLajIxaVhlTWxxaDkK",
      "endpoints": [
        "https://raw.githubusercontent.com/bylazar/Moteus-Testing/main/updates.json"
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}